<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             xmlns:dtos="clr-namespace:SmartHomeEnergyDashboard.DTOs"
             xmlns:vm="clr-namespace:SmartHomeEnergyDashboard.ViewModels"
             x:Class="SmartHomeEnergyDashboard.Views.StatisticsPage"
             Title="Statistics - max 3 days">
    <ScrollView>
    <VerticalStackLayout Spacing="20" Padding="30">
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10" HorizontalOptions="Fill">
                <Button Grid.Column="0"
                        Text="Show Actual Charts"
                        Command="{Binding SetActualDataCommand}"
                        BackgroundColor="#0965c8"
                        TextColor="White"
                        FontSize="18"
                        CornerRadius="10"
                        HeightRequest="60" />
                <Button Grid.Column="1"
                        Text="Import Data"
                        Command="{Binding ImportDataCommand}"
                        BackgroundColor="#0965c8"
                        TextColor="White"
                        FontSize="18"
                        CornerRadius="10"
                        HeightRequest="60" />
                <Button Grid.Column="2"
                        Text="Go Back"
                        Clicked="OnBackClicked"
                        BackgroundColor="#0965c8"
                        TextColor="White"
                        FontSize="18"
                        CornerRadius="10"
                        HeightRequest="60" />
            </Grid>

        <Label Text="Production" 
               FontSize="24" 
               HorizontalOptions="Center" />
        <micro:ChartView 
            Chart="{Binding ProductionChart}" 
            HeightRequest="300" 
            HorizontalOptions="Fill" />

        <Label Text="Consumption" 
               FontSize="24" 
               HorizontalOptions="Center" />
        <micro:ChartView 
                Chart="{Binding ConsumptionChart}" 
                HeightRequest="300" 
                HorizontalOptions="Fill" />

        <Label Text="Balance" 
               FontSize="24" 
               HorizontalOptions="Center" />
            <micro:ChartView 
                Chart="{Binding BalanceChart}" 
                HeightRequest="300" 
                HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>